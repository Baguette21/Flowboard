{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "types": ["react", "react-native"],
    "paths": {
      "@/*": ["src/*"],
      "@convex/*": ["../../convex/*"]
    }
  },
  "include": ["App.tsx", "src/**/*.ts", "src/**/*.tsx", "../../convex/_generated/**/*.ts"],
  "exclude": ["android", "node_modules"]
}
