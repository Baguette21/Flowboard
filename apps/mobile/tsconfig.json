{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@convex/*": [
        "../../convex/*"
      ]
    }
  },
  "include": [
    "App.tsx",
    "index.js",
    "src/**/*.ts",
    "src/**/*.tsx",
    "../../convex/_generated/**/*.ts"
  ],
  "exclude": [
    "android",
    "node_modules"
  ]
}
